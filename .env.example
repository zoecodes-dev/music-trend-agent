# Music Trend Agent — 환경변수 템플릿
# 이 파일을 .env 로 복사한 뒤 각 키 값을 채우세요:  cp .env.example .env
# 코드가 실제로 읽는 키만 포함 (os.getenv 기준 검증됨).

# Claude API — 발굴(Sonnet)·종합(Opus)·Reddit 아티스트 추출(Haiku)
ANTHROPIC_API_KEY=

# Tavily — 웹 검색 (무료 티어 ~1,000회/월). https://tavily.com
TAVILY_API_KEY=

# YouTube Data API v3 — Trending KR + Rising. Google Cloud Console에서 발급
YOUTUBE_API_KEY=

# Last.fm API — Global/US/UK 차트 + 장르 태그. https://www.last.fm/api
LASTFM_API_KEY=

# 참고: Spotify(SPOTIPY_*)는 더 이상 사용하지 않습니다.
# Audio Features API 폐쇄로 구조적 차단 — 키 불필요.
